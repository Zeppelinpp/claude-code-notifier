{
  "description": "Send macOS notification when Codex stops responding",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CODEX_PLUGIN_ROOT}/scripts/notify.sh",
            "statusMessage": "Sending CodePing notification"
          }
        ]
      }
    ]
  }
}
